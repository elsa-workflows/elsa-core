{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CShells": {
    "Shells": [
      {
        "Name": "Default",
        "Configuration": {
          "WebRouting": {
            "Path": "foo"
          }
        },
        "Features": [
          "Elsa",
          "WorkflowsApi",
          "ShellsApi",
          "DefaultAuthentication",
          "Resilience",
          {
            "Name": "Identity",
            "SigningKey": "CHANGE_ME_TO_A_SECURE_RANDOM_KEY"
          },
          {
            "Name": "DefaultAdminUser",
            "AdminUserName": "admin",
            "AdminPassword": "password",
            "AdminRoleName": "admin",
            "AdminRolePermissions": ["*"]
          },
          {
            "Name": "FastEndpoints",
            "GlobalRoutePrefix": "elsa/api"
          },
          {
            "Name": "SqliteWorkflowPersistence",
            "ConnectionString": "Data Source=elsa_workflows.db;Cache=Shared"
          }
        ]
      }
    ]
  }
}
